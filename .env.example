# =============================================================================
# Bandbox — environment variable inventory (PRD §8)
# -----------------------------------------------------------------------------
# This file ships PLACEHOLDERS ONLY. Never commit real values.
# Secrets live ONLY in: local .env (gitignored) / GitHub Actions secrets /
# Supabase Vault. Push-protection + gitleaks CI guard this repo.
#
# Columns documented per var: NAME · OWNER · REQUIRED? · STORAGE LOCATION
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# OWNER: ops · REQUIRED: yes · STORAGE: Actions secret + Vercel env + local .env
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# OWNER: ops · REQUIRED: yes (client) · STORAGE: Vercel env (public) + local .env
SUPABASE_ANON_KEY="REPLACE_ME_anon_publishable_key"
# OWNER: ops · REQUIRED: yes (worker only) · STORAGE: Actions secret ONLY — never client/Vercel-public
SUPABASE_SERVICE_ROLE_KEY="REPLACE_ME_service_role_key"
# OWNER: ops · REQUIRED: yes · STORAGE: Actions secret + local .env · POOLED connection string (pgBouncer 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
# OWNER: ops · REQUIRED: migrations only · STORAGE: Actions secret · DIRECT (5432) for DDL/migrations
DATABASE_URL_DIRECT="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
# OWNER: ops · REQUIRED: skip-trace only · STORAGE: Supabase Vault key id · names the Vault key that decrypts BYO skip-trace keys
SUPABASE_VAULT_KEY_ID="REPLACE_ME_vault_key_uuid"

# --- Stripe (DEFERRED — monetization postponed to M8) -------------------------
# Monetization is deferred: CSV export + skip-trace are free for authenticated
# users. The subscription seam (app.subscription / the `stripe` dep) is kept but
# UNENFORCED — uncomment + set these in M8 to re-arm the paid gates.
# OWNER: aaron · REQUIRED: M8 · STORAGE: Vercel env (server) + local .env
# STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
# OWNER: aaron · REQUIRED: M8 · STORAGE: Vercel env (server) — verifies webhook raw-body signature
# STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"
# OWNER: aaron · REQUIRED: M8 (client) · STORAGE: Vercel env (public)
# STRIPE_PRICE_ID="price_REPLACE_ME"

# --- ZeptoMail (Zoho; alert email digest) -------------------------------------
# OWNER: aaron · REQUIRED: M7 · STORAGE: Actions secret + Vercel env · Send-Mail token (raw HTTPS: `Authorization: Zoho-enczapikey <token>`)
ZEPTOMAIL_TOKEN="REPLACE_ME_zeptomail_send_token"
# OWNER: aaron · REQUIRED: M7 · STORAGE: config — From address (must be a verified ZeptoMail sending domain: DKIM/SPF)
ZEPTOMAIL_FROM="Bandbox <alerts@bandbox.pro>"

# --- Supabase Storage (PMTiles object store, S3-compatible) -------------------
# OWNER: ops · REQUIRED: M4 · STORAGE: Actions secret
# S3 access keys are minted in the Supabase dashboard (Project Settings → Storage →
# S3 Access Keys) — DISTINCT from the anon/service_role keys above.
SUPABASE_S3_ENDPOINT="https://ctcvrdsrylauqpuxbauz.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="us-east-1"
SUPABASE_S3_ACCESS_KEY_ID="REPLACE_ME"
SUPABASE_S3_SECRET_ACCESS_KEY="REPLACE_ME"
SUPABASE_STORAGE_BUCKET="phillybricks-tiles"
# OWNER: ops · REQUIRED: M4 (client) · STORAGE: Vercel env (public) — public PMTiles base
# read CLIENT-SIDE by ScanMap (the `pmtiles` source), so it MUST carry the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_TILES_BASE_URL="https://ctcvrdsrylauqpuxbauz.supabase.co/storage/v1/object/public/phillybricks-tiles"

# --- Liveness / dead-man's-switch (PRD §4.1) ----------------------------------
# OWNER: ops · REQUIRED: M1 · STORAGE: Actions secret · pinged on each successful nightly run; alerts on run ABSENCE
HEALTHCHECKS_URL="https://hc-ping.com/REPLACE_ME"
# OWNER: ops · REQUIRED: M1 · STORAGE: Actions secret · token for the repo-mutating keep-alive commit/issue-comment
KEEPALIVE_TOKEN="REPLACE_ME_github_pat_or_GITHUB_TOKEN"

# --- Feature flags ------------------------------------------------------------
# Bid4Assets sheriff enrichment is OFF by default in the public repo (PRD §4.2)
ENABLE_BID4ASSETS_ENRICHMENT="false"

# NOTE: Carto SQL API needs NO key (public, unauthenticated). The OPA S3 bulk CSV is public.
