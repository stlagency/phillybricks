{
  "name": "bandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source (AGPL), transparency-first Philadelphia residential real-estate market-intelligence tool.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "gate:portability": "node infra/scripts/portability-grep.mjs",
    "gate:security": "node infra/scripts/security-gate.mjs",
    "gate:literals": "node infra/scripts/document-type-literals.mjs",
    "gates": "pnpm gate:portability && pnpm gate:security",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm gates"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
